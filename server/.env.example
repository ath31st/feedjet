# Порт сервера
PORT=2999
# Уровень логирования (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info
# Путь к БД, например ./default.db
DB_FILE_NAME=./default.db
# Частота забора RSS (только при активных SSE-клиентах), например "*/10 * * * *" - раз в 10 минут
RSS_CRON_SCHEDULE="*/10 * * * *"
# TTL кеша RSS в мс (должен соответствовать частоте CRON_SCHEDULE). 600000 = 10 мин
RSS_CACHE_TTL_MS=600000
# Интервал push новостей из кеша по SSE в мс. 30000 = 30 с
RSS_SSE_PUSH_INTERVAL_MS=30000
# Частота очистки кэша, например "0 * * * *" - 1 раз в час
IMAGE_CACHE_CLEANUP_CRON_SCHEDULE="0 * * * *"
# Частота очистки устройств, например "0 19 * * *" - 1 раз в день
DEVICE_CLEANUP_CRON_SCHEDULE="0 19 * * *"
# URL клиента, например: "http://localhost:5123"
CLIENT_URL="http://localhost:5123"
# API ключ от сервиса OpenWeatherMap
OPEN_WEATHER_API_KEY=fGh5JrT6uQb8y2zH4mN0vP7E

# Секретный ключ JWT, например: "super duper secret"
JWT_SECRET="super duper secret"
# Срок действия JWT, например: "1d"
JWT_EXPIRES_IN="1d"

# Ключ для шифрования данных, обязательно 32 байта и префикс "base64:"
# Можно сгенерировать с помощью команды `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
DATA_ENCRYPTION_KEY="base64:Zt1Fq2k3aR9p4sL8Xy+fGh5JrT6uQb8y2zH4mN0vP7E="