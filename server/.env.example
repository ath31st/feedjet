# =============================================================================
# Обязательные
# =============================================================================

# Путь к БД, например ./default.db
DB_FILE_NAME=./default.db

# API ключ от сервиса OpenWeatherMap
OPEN_WEATHER_API_KEY=fGh5JrT6uQb8y2zH4mN0vP7E

# Ключ для шифрования данных, обязательно 32 байта и префикс "base64:"
# Сгенерировать: node -e "console.log('base64:' + require('crypto').randomBytes(32).toString('base64'))"
DATA_ENCRYPTION_KEY="base64:Zt1Fq2k3aR9p4sL8Xy+fGh5JrT6uQb8y2zH4mN0vP7E="

# =============================================================================
# Рекомендуется (в коде есть небезопасные дефолты)
# =============================================================================

# Секретный ключ JWT
JWT_SECRET="super duper secret"

# Срок действия JWT, например "1d"
JWT_EXPIRES_IN="1d"

# =============================================================================
# Необязательные (есть дефолтные значения в коде)
# =============================================================================

# Порт сервера (default: 3000)
# PORT=2999

# Уровень логирования: trace, debug, info, warn, error, fatal (default: info)
# LOG_LEVEL=info

# Директория кеша изображений (default: ./.image-cache)
# CACHE_DIR=./.image-cache

# Директория файлового хранилища (default: ./file-storage)
# FILE_STORAGE_DIR=./file-storage

# Макс. число RSS-элементов при парсинге, если не задан carouselSize (default: 10)
# MAX_ITEMS=10

# --- RSS (fetch только при активных SSE-клиентах) ---

# Частота забора RSS, cron-выражение (default: */10 * * * *)
# RSS_CRON_SCHEDULE="*/10 * * * *"

# TTL кеша RSS в мс, лучше совпадать с RSS_CRON_SCHEDULE (default: 600000)
# RSS_CACHE_TTL_MS=600000

# Интервал push новостей из кеша по SSE в мс (default: 30000)
# RSS_SSE_PUSH_INTERVAL_MS=30000

# --- Cron-задачи ---

# SSE keepalive, cron-выражение с секундами (default: */30 * * * * *)
# CRON_SSE_KEEPALIVE="*/30 * * * * *"

# Опрос состояния экранов TV (default: 0 * * * * *)
# CRON_SCREEN_STATE="0 * * * * *"

# Очистка кеша изображений (default: 0 * * * *)
# IMAGE_CACHE_CLEANUP_CRON_SCHEDULE="0 * * * *"

# Очистка старых устройств (default: 0 19 * * *)
# DEVICE_CLEANUP_CRON_SCHEDULE="0 19 * * *"

# Удалять устройства старше N дней (default: 10)
# DEVICE_CLEANUP_DAYS_THRESHOLD=10
